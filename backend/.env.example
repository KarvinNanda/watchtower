# Server
APP_ENV=development
APP_PORT=8080
# Only enforced when APP_ENV=production (CORS allow-origin)
FRONTEND_URL=

# Database MySQL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=watchtower

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRY_HOURS=24

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Telegram - Asset Bot
TELEGRAM_ASSET_BOT_TOKEN=
# Telegram - Sentinel Bot
TELEGRAM_SENTINEL_BOT_TOKEN=
# polling (development, default) or webhook (production)
TELEGRAM_MODE=polling

# External APIs
TWELVE_DATA_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
OPEN_ER_BASE_URL=https://open.er-api.com/v6/latest/USD
# Optional: raises GitHub API rate limits for sentinel's repo/advisory
# search from 10 req/min (unauthenticated) to 30 req/min.
GITHUB_TOKEN=

# Scheduler
ASSET_SCHEDULER_INTERVAL_HOURS=4
SENTINEL_SCHEDULER_INTERVAL_HOURS=6

# Limits
MAX_UNIQUE_SYMBOLS=100
ALERT_COOLDOWN_HOURS=4
ALERT_PRICE_MOVE_PCT=3
