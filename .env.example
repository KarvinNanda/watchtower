# Root-level env, consumed by docker-compose.yml / docker-compose.prod.yml
# to configure the mysql/redis containers and to override the connection
# settings that api/scheduler get from backend/.env (see the comments in
# docker-compose.yml for why). Copy to .env and fill in real values —
# never commit the real file.

DB_ROOT_PASSWORD=
DB_NAME=watchtower
DB_USER=watchtower
DB_PASSWORD=
REDIS_PASSWORD=

# Domain the production stack is served from (used by nginx/nginx.prod.conf
# and the certbot certificate request) and the email certbot registers
# expiry notifications to.
DOMAIN=
SSL_EMAIL=
