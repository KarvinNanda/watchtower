# Base URL of the WatchTower backend API.
# NOTE: the backend does not use versioned routes (no "/v1") — every
# endpoint lives under /api directly, e.g. /api/auth/login.
VITE_API_BASE_URL=http://localhost:8080/api

# Public Telegram bot usernames shown in the Telegram setup guide (no "@").
VITE_ASSET_BOT_USERNAME=WatchTowerAssetBot
VITE_SENTINEL_BOT_USERNAME=WatchTowerSentinelBot
